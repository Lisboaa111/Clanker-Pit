# ── Chain selection ────────────────────────────────────────────────────────────
# Set CHAIN=local to run against a local Hardhat node (skips tx verification)
# Set CHAIN=sepolia for the real testnet
CHAIN=local

# ── Local Hardhat node (default for development) ───────────────────────────────
SEPOLIA_RPC_URL=http://127.0.0.1:8545
# After running `cd contracts && npm run deploy:local`:
ARENA_ADDRESS=0x0000000000000000000000000000000000000000
# Use any Hardhat test account private key (printed by `npx hardhat node`)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Platform address = deployer address for local dev
PLATFORM_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# ── Sepolia (uncomment and fill for testnet) ───────────────────────────────────
# CHAIN=sepolia
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
# ARENA_ADDRESS=0x...
# DEPLOYER_PRIVATE_KEY=0x...
# PLATFORM_ADDRESS=0x...

# ── App ─────────────────────────────────────────────────────────────────────────
PORT=3001

# ── OpenRouter (for LLM agents) ─────────────────────────────────────────────────
OPENROUTER_API_KEY=
